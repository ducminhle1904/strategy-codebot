{
  "provider": "ccxt-public-readonly",
  "default_exchange": "binance",
  "allowed_exchanges": ["binance", "bybit", "okx", "kraken"],
  "executable_timeframes": ["1m", "3m", "5m", "15m", "30m", "1h"],
  "max_cost_bps": 1000,
  "run_events": {
    "queued": "backtest.queued",
    "dataStarted": "backtest.data.started",
    "dataPlanning": "backtest.data.planning",
    "dataCacheReusing": "backtest.data.cache_reusing",
    "dataFetching": "backtest.data.fetching",
    "dataExporting": "backtest.data.exporting",
    "dataCompleted": "backtest.data.completed",
    "executionStarted": "backtest.execution.started",
    "executionCompleted": "backtest.execution.completed",
    "indexingStarted": "backtest.indexing.started",
    "reportCompleted": "backtest.report.completed",
    "failed": "backtest.failed"
  }
}
