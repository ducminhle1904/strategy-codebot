{
  "schema_version": 1,
  "component_kinds": [
    "workflow_header",
    "badge_row",
    "step_checklist",
    "field_status_section",
    "artifact_refs_section",
    "review_status_section",
    "action_gate_section",
    "custom_adapter_section"
  ],
  "task_kinds": [
    "input_request",
    "choice_request",
    "artifact_review",
    "repair_decision",
    "confirmation_gate",
    "background_status"
  ],
  "workflows": {
    "strategy_bot_simulation": {
      "intent": "strategy_to_paper_bot_simulation",
      "title": "Strategy -> Paper Bot",
      "aria_label": "Strategy to Paper Bot workflow",
      "icon_key": "bot",
      "badges": [
        "Paper simulation only",
        "No broker execution",
        "Review-only evidence"
      ],
      "steps": [
        {
          "id": "collect_strategy_inputs",
          "label": "Collect strategy inputs"
        },
        {
          "id": "draft_strategy_spec",
          "label": "Draft strategy spec"
        },
        {
          "id": "generate_pine",
          "label": "Generate Pine strategy",
          "optional": true,
          "skip_label": "Skipped"
        },
        {
          "id": "static_validation",
          "label": "Static validation/repair",
          "optional": true,
          "skip_label": "Not applicable"
        },
        {
          "id": "backtest_preview",
          "label": "Backtest preview",
          "optional": true,
          "skip_label": "Skipped"
        },
        {
          "id": "evidence_review",
          "label": "Evidence review",
          "optional": true,
          "skip_label": "Skipped"
        },
        {
          "id": "draft_bot_proposal",
          "label": "Draft Bot proposal"
        },
        {
          "id": "complete_setup_confirm_start",
          "label": "Complete setup + confirm paper start"
        }
      ],
      "status_labels": {
        "insufficient_evidence": {
          "key": "insufficient_evidence",
          "label": "Insufficient evidence",
          "tone": "neutral"
        },
        "reviewable_with_caveats": {
          "key": "reviewable_with_caveats",
          "label": "Reviewable with caveats",
          "tone": "success"
        },
        "needs_validation_or_robustness_check": {
          "key": "needs_validation_or_robustness_check",
          "label": "Needs validation or robustness check",
          "tone": "warning"
        }
      },
      "default_status": "insufficient_evidence",
      "allowed_section_kinds": [
        "field_status_section",
        "artifact_refs_section",
        "review_status_section",
        "action_gate_section",
        "custom_adapter_section"
      ],
      "input_fields": [
        "market",
        "symbol",
        "timeframe",
        "style",
        "entry_exit_idea",
        "risk_preference"
      ],
      "required_input_fields": [
        "market",
        "symbol",
        "timeframe",
        "style",
        "risk_preference"
      ],
      "setup_fields": [
        "broker_connection_id",
        "account_id",
        "risk_policy_id",
        "strategy_id",
        "data_subscriptions"
      ],
      "allowed_fields": [
        "next_after_strategy_spec"
      ],
      "option_sets": {
        "market_defaults": [
          {
            "id": "crypto",
            "value": "crypto",
            "label": "Crypto"
          },
          {
            "id": "stock",
            "value": "stock",
            "label": "Stock"
          },
          {
            "id": "forex",
            "value": "forex",
            "label": "Forex"
          }
        ],
        "timeframe_defaults": [
          {
            "id": "15m",
            "value": "15m",
            "label": "15m"
          },
          {
            "id": "1h",
            "value": "1h",
            "label": "1h"
          },
          {
            "id": "4h",
            "value": "4h",
            "label": "4h"
          },
          {
            "id": "1d",
            "value": "1d",
            "label": "1d"
          }
        ],
        "strategy_style_defaults": [
          {
            "id": "trend",
            "value": "trend",
            "label": "Trend"
          },
          {
            "id": "mean_reversion",
            "value": "mean_reversion",
            "label": "Mean reversion"
          },
          {
            "id": "breakout",
            "value": "breakout",
            "label": "Breakout"
          },
          {
            "id": "scalping",
            "value": "scalping",
            "label": "Scalping"
          },
          {
            "id": "dca",
            "value": "dca",
            "label": "DCA"
          }
        ],
        "risk_preference_defaults": [
          {
            "id": "conservative",
            "value": "conservative",
            "label": "Conservative"
          },
          {
            "id": "balanced",
            "value": "balanced",
            "label": "Balanced"
          },
          {
            "id": "aggressive",
            "value": "aggressive",
            "label": "Aggressive"
          }
        ],
        "draft_only_choices": [
          {
            "id": "run_preview",
            "value": "run_preview",
            "label": "Run preview"
          },
          {
            "id": "draft_only",
            "value": "draft_only",
            "label": "Draft only"
          }
        ],
        "strategy_spec_next_actions": [
          {
            "id": "generate_pine",
            "value": "generate_pine",
            "label": "Generate Pine Script"
          },
          {
            "id": "revise_strategy_spec",
            "value": "revise_strategy_spec",
            "label": "Revise strategy spec"
          },
          {
            "id": "skip_pine",
            "value": "skip_pine",
            "label": "Skip Pine"
          }
        ]
      },
      "input_request_templates": [
        {
          "id": "market",
          "field": "market",
          "label": "Market",
          "question": "Which market should this strategy trade?",
          "kind": "select_or_text",
          "required": true,
          "placeholder": "Choose or enter market",
          "option_set_id": "market_defaults",
          "allow_custom": true,
          "recommended_option_id": "crypto",
          "custom_option_label": "Use another market"
        },
        {
          "id": "symbol",
          "field": "symbol",
          "label": "Symbol",
          "question": "Which symbol should the strategy watch?",
          "kind": "text",
          "required": true,
          "placeholder": "BTCUSDT",
          "allow_custom": true,
          "recommended_option_id": "btcusdt",
          "custom_option_label": "Enter another symbol",
          "options": [
            {
              "id": "btcusdt",
              "value": "BTCUSDT",
              "label": "BTCUSDT"
            },
            {
              "id": "ethusdt",
              "value": "ETHUSDT",
              "label": "ETHUSDT"
            },
            {
              "id": "aapl",
              "value": "AAPL",
              "label": "AAPL"
            }
          ]
        },
        {
          "id": "timeframe",
          "field": "timeframe",
          "label": "Timeframe",
          "question": "Which timeframe should the strategy use?",
          "kind": "select_or_text",
          "required": true,
          "placeholder": "1h",
          "option_set_id": "timeframe_defaults",
          "allow_custom": true,
          "recommended_option_id": "1h",
          "custom_option_label": "Use another timeframe"
        },
        {
          "id": "style",
          "field": "style",
          "label": "Style",
          "question": "What style should the strategy follow?",
          "kind": "select_or_text",
          "required": true,
          "option_set_id": "strategy_style_defaults",
          "allow_custom": true,
          "recommended_option_id": "trend",
          "custom_option_label": "Describe another style"
        },
        {
          "id": "entry_exit_idea",
          "field": "entry_exit_idea",
          "label": "Entry/exit idea",
          "question": "Do you already have an entry or exit idea?",
          "kind": "textarea",
          "required": false,
          "placeholder": "Optional entry or exit logic",
          "allow_custom": true,
          "recommended_option_id": "ma_cross",
          "custom_option_label": "Write a different idea",
          "options": [
            {
              "id": "ma_cross",
              "value": "moving average crossover",
              "label": "MA crossover"
            },
            {
              "id": "rsi_reversal",
              "value": "RSI overbought/oversold reversal",
              "label": "RSI reversal"
            },
            {
              "id": "breakout_volume",
              "value": "breakout with volume confirmation",
              "label": "Breakout + volume"
            }
          ]
        },
        {
          "id": "risk_preference",
          "field": "risk_preference",
          "label": "Risk preference",
          "question": "What risk preference should guide the design?",
          "kind": "select_or_text",
          "required": true,
          "option_set_id": "risk_preference_defaults",
          "allow_custom": true,
          "recommended_option_id": "balanced",
          "custom_option_label": "Describe another risk preference"
        },
        {
          "id": "broker_connection_id",
          "field": "broker_connection_id",
          "label": "Broker connection",
          "question": "Which paper broker connection should this simulation use?",
          "kind": "text",
          "required": true,
          "allow_custom": true,
          "custom_option_label": "Enter broker connection id"
        },
        {
          "id": "account_id",
          "field": "account_id",
          "label": "Account",
          "question": "Which paper account should receive the simulation?",
          "kind": "text",
          "required": true,
          "allow_custom": true,
          "custom_option_label": "Enter account id"
        },
        {
          "id": "risk_policy_id",
          "field": "risk_policy_id",
          "label": "Risk policy",
          "question": "Which risk policy should gate the paper bot?",
          "kind": "text",
          "required": true,
          "allow_custom": true,
          "custom_option_label": "Enter risk policy id"
        },
        {
          "id": "strategy_id",
          "field": "strategy_id",
          "label": "Strategy",
          "question": "Which reviewed strategy should the bot proposal use?",
          "kind": "text",
          "required": true,
          "allow_custom": true,
          "custom_option_label": "Enter strategy id"
        },
        {
          "id": "data_subscriptions",
          "field": "data_subscriptions",
          "label": "Data subscriptions",
          "question": "Which symbols/timeframes/data subscriptions are required?",
          "kind": "textarea",
          "required": true,
          "placeholder": "BTCUSDT 1h",
          "allow_custom": true,
          "custom_option_label": "Enter subscriptions"
        },
        {
          "id": "draft_only_choice",
          "field": "entry_exit_idea",
          "label": "Backtest preference",
          "question": "How should we handle the backtest preview for this draft?",
          "kind": "single_select",
          "required": false,
          "option_set_id": "draft_only_choices",
          "recommended_option_id": "run_preview"
        },
        {
          "id": "next_after_strategy_spec",
          "field": "next_after_strategy_spec",
          "label": "Next step",
          "question": "Strategy spec is ready. What should we do next?",
          "kind": "select_or_text",
          "required": true,
          "option_set_id": "strategy_spec_next_actions",
          "allow_custom": true,
          "recommended_option_id": "generate_pine",
          "custom_option_label": "Tell the model what to do differently"
        }
      ],
      "task_templates": [
        {
          "id": "collect_strategy_inputs",
          "step_id": "collect_strategy_inputs",
          "kind": "input_request",
          "title": "Strategy inputs",
          "blocking": true,
          "input_request_ids": [
            "market",
            "symbol",
            "timeframe",
            "style",
            "entry_exit_idea",
            "risk_preference"
          ],
          "action_ids": [],
          "default_status": "pending_user",
          "resume_on_complete": true,
          "resume_intent": "strategy_building"
        },
        {
          "id": "draft_only_backtest_choice",
          "step_id": "backtest_preview",
          "kind": "choice_request",
          "title": "Backtest preview choice",
          "blocking": true,
          "input_request_ids": [
            "draft_only_choice"
          ],
          "action_ids": [],
          "default_status": "pending_user"
        },
        {
          "id": "review_strategy_spec_next_step",
          "step_id": "generate_pine",
          "kind": "choice_request",
          "title": "Review strategy spec next step",
          "blocking": true,
          "input_request_ids": [
            "next_after_strategy_spec"
          ],
          "action_ids": [],
          "default_status": "pending_user",
          "resume_on_complete": true,
          "resume_intent": "strategy_building"
        },
        {
          "id": "complete_paper_setup",
          "step_id": "complete_setup_confirm_start",
          "kind": "input_request",
          "title": "Paper setup fields",
          "blocking": true,
          "input_request_ids": [
            "broker_connection_id",
            "account_id",
            "risk_policy_id",
            "strategy_id",
            "data_subscriptions"
          ],
          "action_ids": [
            "confirm_paper_start"
          ],
          "default_status": "pending_user"
        },
        {
          "id": "confirm_paper_start",
          "step_id": "complete_setup_confirm_start",
          "kind": "confirmation_gate",
          "title": "Confirm paper simulation",
          "blocking": true,
          "input_request_ids": [],
          "action_ids": [
            "confirm_paper_start"
          ],
          "default_status": "blocked"
        }
      ],
      "sections": [
        {
          "id": "strategy_inputs",
          "component_kind": "field_status_section",
          "title": "Strategy inputs",
          "fields_from": "input_fields"
        },
        {
          "id": "paper_setup",
          "component_kind": "action_gate_section",
          "title": "Paper setup",
          "fields_from": "setup_fields",
          "pending_label": "Waiting for fields",
          "ready_label": "Ready to confirm",
          "locked_message": "Start paper simulation is locked until setup is complete.",
          "action_id": "confirm_paper_start"
        }
      ],
      "actions": [
        {
          "id": "confirm_paper_start",
          "kind": "confirm_start_bot_proposal",
          "label": "Start paper simulation",
          "enabled": false,
          "disabled_reason": "Setup fields are incomplete."
        }
      ],
      "model_guidance": [
        "Use for Strategy to Paper Bot Simulation requests.",
        "Model may propose workflow intent and next step only; registry validates UI sections.",
        "Model may propose task_template_id, short question copy, options, recommended option ids, and reasons; backend validates task state.",
        "Model may suggest skipped or not-applicable steps only for optional registry steps and must provide a short reason.",
        "Keep paper simulation boundaries visible.",
        "Do not represent broker execution or live trading evidence.",
        "Do not use skipped steps to unlock paper start or bypass proposal confirmation.",
        "Do not start runtime without proposal confirmation."
      ]
    }
  }
}
