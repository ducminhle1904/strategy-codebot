# Strategy Codebot local environment template.
# Copy to .env for Docker Compose or export selected variables in your shell.
# Do not commit real API keys or secrets.

# ---------------------------------------------------------------------------
# Docker Compose local stack
# ---------------------------------------------------------------------------
# Docker Compose reads this file automatically when it is copied to .env.
POSTGRES_PASSWORD=replace-me-postgres-password
REDIS_PASSWORD=replace-me-redis-password

# Optional local E2E tests that target exposed compose.dev.yml ports.
STRATEGY_CODEBOT_API_E2E_POSTGRES_URL=postgresql+psycopg://strategy_codebot:replace-me-postgres-password@127.0.0.1:5432/strategy_codebot
STRATEGY_CODEBOT_API_E2E_REDIS_URL=redis://:replace-me-redis-password@127.0.0.1:6379/0

# API server
STRATEGY_CODEBOT_API_ARTIFACT_ROOT=/var/lib/strategy-codebot/artifacts
STRATEGY_CODEBOT_API_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
STRATEGY_CODEBOT_API_CORS_ORIGIN_REGEX=
STRATEGY_CODEBOT_INTERNAL_AUTH_SECRET=
STRATEGY_CODEBOT_LLM_REQUEST_TIMEOUT_SECONDS=90
STRATEGY_CODEBOT_SERVER_USER_TIER=free
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
MARKET_DATA_PROVIDER=auto
MARKET_DATA_TIMEOUT_MS=6000
CCXT_EXCHANGE_ID=binance
CCXT_FALLBACK_EXCHANGES=binance,kraken,coinbase
CCXT_OHLCV_TIMEFRAME=1h
CCXT_OHLCV_LIMIT=72

# Web frontend / Next.js BFF
# Docker Compose overrides STRATEGY_CODEBOT_API_BASE_URL to http://api:8000 for the web container.
STRATEGY_CODEBOT_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_STRATEGY_CODEBOT_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
STRATEGY_CODEBOT_USER_ID=local-user
STRATEGY_CODEBOT_WORKSPACE_ID=local-workspace
STRATEGY_CODEBOT_USER_TIER=free
STRATEGY_CODEBOT_CHAT_FIRST_EVENT_TIMEOUT_MS=45000
STRATEGY_CODEBOT_CHAT_IDLE_TIMEOUT_MS=60000
STRATEGY_CODEBOT_CHAT_TOTAL_TIMEOUT_MS=180000
STRATEGY_CODEBOT_WEB_DEBUG=1

# Optional Clerk auth. Leave empty for local no-auth mode.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Knowledge Base
STRATEGY_CODEBOT_KNOWLEDGE_DATABASE_URL=postgresql://strategy_codebot:replace-me-postgres-password@127.0.0.1:5432/strategy_codebot
STRATEGY_CODEBOT_KNOWLEDGE_INDEX=
STRATEGY_CODEBOT_KNOWLEDGE_CANDIDATES_PATH=

# ---------------------------------------------------------------------------
# Primary LLM providers
# ---------------------------------------------------------------------------
# OpenAI is used for direct paid models and OpenAI embeddings.
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_API_BASE=https://api.openai.com/v1/embeddings

# OpenRouter is the default cheap/free gateway route and production KB embedding route.
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDINGS_API_BASE=https://openrouter.ai/api/v1/embeddings

# Optional direct providers.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=

# ---------------------------------------------------------------------------
# Gateway/load-balancing providers
# ---------------------------------------------------------------------------
# LiteLLM Proxy requires a running proxy URL.
LITELLM_API_KEY=
LITELLM_MASTER_KEY=sk-litellm-local-dev-change-me
LITELLM_SALT_KEY=change-me-long-random-value
LITELLM_ADMIN_API_BASE=http://127.0.0.1:4000
LITELLM_PROXY_API_KEY=sk-litellm-local-dev-change-me
LITELLM_PROXY_API_BASE=http://litellm-proxy:4000/v1
LITELLM_BUDGET_PAID_LOW_DAILY_USD=2
LITELLM_BUDGET_PAID_MEDIUM_DAILY_USD=10
LITELLM_BUDGET_PAID_HIGH_DAILY_USD=50
LITELLM_BUDGET_PAID_LOW_MONTHLY_USD=30
LITELLM_BUDGET_PAID_MEDIUM_MONTHLY_USD=150
LITELLM_BUDGET_PAID_HIGH_MONTHLY_USD=750

# Vercel AI Gateway defaults to https://ai-gateway.vercel.sh/v1 when base is empty.
VERCEL_AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_API_BASE=https://ai-gateway.vercel.sh/v1

# Portkey defaults to https://api.portkey.ai/v1 when base is empty.
PORTKEY_API_KEY=
PORTKEY_API_BASE=https://api.portkey.ai/v1
PORTKEY_VIRTUAL_KEY=
PORTKEY_CONFIG_ID=

# Debug only. Leave disabled in normal runs because provider logs may be noisy.
STRATEGY_CODEBOT_LITELLM_DEBUG=
