# Strategy Codebot minimal environment template.
# Copy to .env for local development. Do not commit real secrets.

# ---------------------------------------------------------------------------
# Local infrastructure secrets
# ---------------------------------------------------------------------------
# Required by Docker Compose. Use strong values outside local development.
POSTGRES_PASSWORD=replace-me-postgres-password
REDIS_PASSWORD=replace-me-redis-password

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
# Optional when running the API directly; compose wires this automatically.
STRATEGY_CODEBOT_API_DATABASE_URL=
STRATEGY_CODEBOT_API_REDIS_URL=
STRATEGY_CODEBOT_API_ARTIFACT_ROOT=/var/lib/strategy-codebot/artifacts
STRATEGY_CODEBOT_API_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
STRATEGY_CODEBOT_API_CORS_ORIGIN_REGEX=
STRATEGY_CODEBOT_INTERNAL_AUTH_SECRET=

# ---------------------------------------------------------------------------
# Model routing
# ---------------------------------------------------------------------------
# Registry mode and registry path are code defaults. Local dev uses direct
# OpenRouter routes so it does not require a local LiteLLM proxy.
STRATEGY_CODEBOT_SERVER_USER_TIER=dev

# OpenRouter is the easiest local route. Add other provider keys only when the
# selected registry/fixed route needs them.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
VERCEL_AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=

# Optional fixed-provider override. Leave empty for registry routing.
STRATEGY_CODEBOT_LLM_PROVIDER=
STRATEGY_CODEBOT_LLM_MODEL=

# ---------------------------------------------------------------------------
# Optional market data credentials
# ---------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# ---------------------------------------------------------------------------
# Web frontend / Next.js BFF
# ---------------------------------------------------------------------------
# Standalone web dev values. Docker Compose overrides server-side API URL.
STRATEGY_CODEBOT_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_STRATEGY_CODEBOT_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
STRATEGY_CODEBOT_USER_ID=local-user
STRATEGY_CODEBOT_WORKSPACE_ID=local-workspace
STRATEGY_CODEBOT_USER_TIER=dev

# Optional Clerk auth. Leave empty for local no-auth mode.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
