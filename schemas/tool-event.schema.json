{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ducminhle1904/strategy-codebot/schemas/tool-event.schema.json",
  "title": "ToolEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["sequence", "created_at", "run_id", "event_type", "policy_mode"],
  "properties": {
    "sequence": { "type": "integer", "minimum": 1 },
    "event_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "enum": [
        "agent.started",
        "agent.handoff",
        "llm.started",
        "llm.completed",
        "tool.started",
        "tool.completed",
        "tool.failed",
        "tool.blocked",
        "guardrail.blocked",
        "repair.started",
        "repair.completed",
        "agent.completed",
        "evaluator_optimizer.summary",
        "agent_loop.started",
        "agent_loop.llm_completed",
        "agent_loop.tool_checked",
        "agent_loop.completed"
      ]
    },
    "case_id": { "type": "string" },
    "workflow": { "type": "string" },
    "user_tier": { "type": "string" },
    "cost_profile": { "type": "string" },
    "stage": { "type": "string" },
    "agent_role": { "type": "string" },
    "model": { "type": "string" },
    "provider": { "type": "string" },
    "model_stage": { "type": "string" },
    "provider_route": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1 },
    "iteration": { "type": "integer", "minimum": 0 },
    "parent_event_id": { "type": "string" },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "usage": {
      "type": "object",
      "additionalProperties": true
    },
    "gate": { "type": "string" },
    "decision": { "type": "string" },
    "reason_code": { "type": "string" },
    "tool_call_count": { "type": "integer", "minimum": 0 },
    "budget_exhausted": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "string" }
      ]
    },
    "stop_reason": { "type": "string" },
    "repair_count": { "type": "integer", "minimum": 0 },
    "repair_source_mix": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "final_validation_status": { "type": "string" },
    "final_review_status": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["started", "pass", "fail", "blocked", "skipped"]
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "missing_credential",
        "provider_rate_limited",
        "provider_timeout",
        "provider_not_found",
        "malformed_response",
        "schema_invalid",
        "policy_violation",
        "static_validation_failed",
        "review_failed",
        "review_validation_disagreement",
        "artifact_missing",
        "free_capacity_unavailable",
        "tool_error",
        "provider_error",
        "unknown"
      ]
    },
    "tool_id": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "input_summary": { "type": "string" },
    "output_summary": { "type": "string" },
    "tool_user_summary": { "type": "string" },
    "policy_mode": {
      "type": "string",
      "enum": ["observe", "enforce"]
    },
    "risk_tier": { "type": "string", "minLength": 1 },
    "input_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "output_refs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
