{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ducminhle1904/strategy-codebot/schemas/knowledge-diff.schema.json",
  "title": "KnowledgeDiff",
  "type": "object",
  "additionalProperties": false,
  "required": ["baseline_ref", "current_ref", "created_at", "status", "summary", "changed_sources", "added_sources", "removed_sources", "unchanged_sources", "warnings", "next_actions"],
  "properties": {
    "baseline_ref": { "type": "string", "minLength": 1 },
    "current_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["pass", "manual_required", "fail"] },
    "summary": { "type": "string" },
    "changed_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_change" }
    },
    "added_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_change" }
    },
    "removed_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_change" }
    },
    "unchanged_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "source_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "platform", "type", "trust_level", "change_type", "manual_required"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "platform": { "type": "string" },
        "type": { "type": "string" },
        "trust_level": { "type": "string" },
        "change_type": { "type": "string", "enum": ["changed", "added", "removed"] },
        "manual_required": { "type": "boolean" },
        "baseline_hash": { "type": "string" },
        "current_hash": { "type": "string" }
      }
    }
  }
}
