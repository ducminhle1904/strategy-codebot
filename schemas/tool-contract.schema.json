{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ducminhle1904/strategy-codebot/schemas/tool-contract.schema.json",
  "title": "ToolContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "capability",
    "risk_tier",
    "input_schema_ref",
    "output_schema_ref",
    "evidence_required",
    "phase_status"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "capability": { "type": "string", "minLength": 1 },
    "risk_tier": {
      "type": "string",
      "enum": ["read", "documentation", "code_generation", "validation", "review", "repo_write", "broker_write", "destructive"]
    },
    "input_schema_ref": { "type": "string", "minLength": 1 },
    "output_schema_ref": { "type": "string", "minLength": 1 },
    "evidence_required": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "phase_status": {
      "type": "string",
      "enum": ["implemented", "planned", "manual_required", "skipped"]
    },
    "backend_handler": { "type": "string", "minLength": 1 },
    "provider_exposed": { "type": "boolean" },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "card_kind": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "preferred_artifact_kind": { "type": "string", "minLength": 1 },
        "source_payload_path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
