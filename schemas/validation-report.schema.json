{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ducminhle1904/strategy-codebot/schemas/validation-report.schema.json",
  "title": "ValidationReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["platform", "status", "checks", "evidence", "warnings", "next_actions"],
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["pine_v6", "mql5", "both"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "manual_required", "skipped"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "manual_required", "skipped"]
          },
          "details": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
