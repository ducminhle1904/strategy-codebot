{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ducminhle1904/strategy-codebot/schemas/strategy-spec.schema.json",
  "title": "StrategySpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_platform",
    "script_type",
    "market",
    "timeframe",
    "entry_rules",
    "exit_rules",
    "risk_rules"
  ],
  "properties": {
    "target_platform": {
      "type": "string",
      "enum": ["pine_v6", "mql5", "both"]
    },
    "script_type": {
      "type": "string",
      "enum": ["indicator", "strategy", "expert_advisor"]
    },
    "market": {
      "type": "string",
      "minLength": 1
    },
    "symbol": {
      "type": "string"
    },
    "timeframe": {
      "type": "string",
      "minLength": 1
    },
    "entry_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "exit_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "risk_rules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "position_sizing": {
      "type": "string"
    },
    "stop_loss": {
      "type": "string"
    },
    "take_profit": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "user_notes": {
      "type": "string"
    }
  }
}
