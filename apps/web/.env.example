# Strategy Codebot web environment template.
# Copy to apps/web/.env.local for standalone Next.js development.
# Do not commit real secrets.

# Server-side backend URL used by the Next.js API proxy.
STRATEGY_CODEBOT_API_BASE_URL=http://127.0.0.1:8000

# Optional browser-visible fallback URL. Most app traffic should use /api/backend.
NEXT_PUBLIC_STRATEGY_CODEBOT_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Local/demo identity passed from the web proxy to the API.
STRATEGY_CODEBOT_USER_ID=local-user
STRATEGY_CODEBOT_WORKSPACE_ID=local-workspace
STRATEGY_CODEBOT_USER_TIER=dev
STRATEGY_CODEBOT_INTERNAL_AUTH_SECRET=

# Chat/proxy timeout overrides in milliseconds. Code defaults are:
# first event 90000, idle 60000, total 180000.
# STRATEGY_CODEBOT_CHAT_FIRST_EVENT_TIMEOUT_MS=90000
# STRATEGY_CODEBOT_CHAT_IDLE_TIMEOUT_MS=60000
# STRATEGY_CODEBOT_CHAT_TOTAL_TIMEOUT_MS=180000

# Debug flags are off by default.
STRATEGY_CODEBOT_WEB_DEBUG=0
NEXT_PUBLIC_DEBUG_AG_UI=false
STRATEGY_CODEBOT_DEBUG_AG_UI=false

# Optional Clerk auth. Leave empty for local no-auth mode.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
